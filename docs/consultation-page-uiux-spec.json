  "section6_cscx_workflow": {
    "title": "F. CS/CX 전담 워크플로우",

    "scenario1_incoming_call": {
      "name": "전화 인입 → 고객 확인 → 상담 기록 → 후속 발송",
      "steps": [
        "1. CS/CX 담당자가 전화 수신",
        "2. /2 (상담 내역 페이지) 진입 → keyword 필드에 고객 전화번호 입력",
        "3. 자동 포커스된 검색창에 바로 타이핑 시작 (autoFocus)",
        "4. Enter → API 호출 → 이전 상담 이력 목록 표시",
        "5. 가장 최근 상담 행 클릭 → SidePanel에 이전 상담 내용 표시",
        "6. 통화 종료 후 [+ 상담 기록] 버튼 클릭 → 새 상담 기록 추가",
        "7. 필요 시 [📧 이메일] → 발송 모달 → 내용 작성 → 발송 → MailLog 기록"
      ],
      "target_time": "3초 이내 고객 컨텍스트 파악 (검색 → 이전 상담 확인)",
      "accessibility": "autoFocus + Enter key + keyboard navigation (Tab between elements)"
    },

    "scenario2_proactive_followup": {
      "name": "미응대 건 확인 → 후속 연락",
      "steps": [
        "1. '내 상담만' 체크박스 활성화 → 본인 담당 건만 필터",
        "2. 기간 7일 → 미응대 건 식별 (linkedTicketNo null + 유형 'A/S문의')",
        "3. 대상 건 클릭 → SidePanel에서 내용 확인",
        "4. [📱 SMS] → 후속 안내 문자 발송",
        "5. 필요 시 [+ A/S 접수] → 티켓 생성으로 이동"
      ]
    },

    "scenario3_team_lead_monitoring": {
      "name": "팀장이 팀 상담 현황 모니터링",
      "steps": [
        "1. 담당자 필터: '전체' (팀 전체 조회)",
        "2. KPI 카드로 금일 상담량 + 채널별 분포 확인",
        "3. 금일 A/S 연결 건수 확인 (asLinkedCount KPI)",
        "4. 특정 담당자 필터 → 개인별 상담량 확인",
        "5. 필요 시 Excel 다운로드 (header [📤 Excel] 버튼)"
      ]
    },

    "keyboard_shortcuts": {
      "Enter": "검색 실행",
      "Escape": "SidePanel/Modal 닫기",
      "ArrowUp/Down": "목록 행 선택 이동 (선택 행 → SidePanel 갱신)",
      "Ctrl+E": "선택 건 이메일 발송 모달 열기",
      "Ctrl+S": "선택 건 SMS 발송 모달 열기"
    },

    "accessibility_features": [
      "autoFocus on keyword search (전화 중 즉시 타이핑)",
      "Enter key for search submit",
      "Arrow keys for list navigation",
      "Ctrl shortcuts for frequent actions",
      "Visible focus indicators on all interactive elements",
      "aria-label on all buttons",
      "Screen reader: '상담 42건 중 1페이지' 읽기"
    ]
  },

  "section7_api_endpoints": {
    "title": "G. API 엔드포인트",

    "endpoints": [
      {
        "method": "GET", "path": "/api/consults",
        "params": "keyword, channel, consultType, assignee, dateFrom, dateTo, page, size, sort",
        "response": "PageResponse<ConsultationSummary>",
        "rbac": "ALL (AS_ENGINEER: auto-filter assignee=self)"
      },
      {
        "method": "GET", "path": "/api/consults/{id}",
        "response": "ConsultationDetail (with full content)",
        "rbac": "ALL"
      },
      {
        "method": "GET", "path": "/api/consults/summary",
        "params": "from, to",
        "response": "{ todayTotal, phoneCount, kakaoCount, emailSmsCount, asLinkedCount }",
        "rbac": "ALL"
      },
      {
        "method": "POST", "path": "/api/consults",
        "body": "{ customerPhone, channel, consultType, summary, content }",
        "response": "ConsultationDetail",
        "rbac": "CS_CX, TEAM_LEAD, ADMIN"
      },
      {
        "method": "PATCH", "path": "/api/consults/{id}",
        "body": "{ summary?, content? }",
        "response": "ConsultationDetail",
        "rbac": "ADMIN only"
      },
      {
        "method": "DELETE", "path": "/api/consults/{id}",
        "response": "204",
        "rbac": "ADMIN only"
      }
    ]
  },

