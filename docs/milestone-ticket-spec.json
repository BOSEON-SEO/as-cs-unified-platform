  "required_apis": [
    { "method": "GET",  "path": "/api/tickets/{id}",                  "desc": "티켓 상세 (현재 step, 고객/제품 포함)", "priority": "P0" },
    { "method": "PUT",  "path": "/api/tickets/{id}/step",             "desc": "단계 전진/후퇴", "priority": "P0" },
    { "method": "POST", "path": "/api/tickets/{id}/assignment",        "desc": "엔지니어 배정", "priority": "P0" },
    { "method": "POST", "path": "/api/tickets/{id}/diagnosis",         "desc": "진단결과 + 처리방향 기록", "priority": "P0" },
    { "method": "GET",  "path": "/api/tickets/{id}/events",           "desc": "TicketEvent 목록 (타임라인)", "priority": "P0" },
    { "method": "POST", "path": "/api/tickets/{id}/events",           "desc": "수동 이벤트 기록 (PHONE_CALL 등)", "priority": "P0" },
    { "method": "POST", "path": "/api/tickets/{id}/cost-entries",     "desc": "비용 항목 추가", "priority": "P0" },
    { "method": "PUT",  "path": "/api/tickets/{id}/cost-entries/{cid}","desc": "비용 항목 수정", "priority": "P1" },
    { "method": "POST", "path": "/api/tickets/{id}/shipments",        "desc": "출고 등록", "priority": "P0" },
    { "method": "POST", "path": "/api/tickets/{id}/pickups",          "desc": "회수 요청", "priority": "P0" },
