    { "method": "GET",  "path": "/api/users?role=AS_ENGINEER",        "desc": "배정 가능 엔지니어 목록", "priority": "P0" },
    { "method": "GET",  "path": "/api/ai/similar-cases",             "desc": "유사 케이스 조회 (suggestion)", "priority": "P1" },
    { "method": "POST", "path": "/api/ai/draft-reply",               "desc": "답변 초안 생성 (suggestion)", "priority": "P1" }
  ],

