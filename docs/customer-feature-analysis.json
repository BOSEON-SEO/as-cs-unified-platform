  "section6_data_structure": {
    "title": "6. 데이터 구조",

    "customer": {
      "table": "기존 고객 테이블 (정확한 스키마는 Spring DB 확인 필요)",
      "typescript_interface": {
        "customerId": "number (PK)",
        "phone": "string (조회 PK, CLAUDE.md 규칙)",
        "name": "string",
        "email": "string | null",
        "address": "string | null",
        "grade": "'VIP' | 'NORMAL'",
        "registeredAt": "string (ISO8601)",
        "totalPurchaseAmount": "number (서버 집계)",
        "lastPurchaseDate": "string | null (서버 집계)",
        "asCount": "number (서버 집계)",
        "activeAsCount": "number (서버 집계)",
        "lastConsultationDate": "string | null (서버 집계)",
        "registrationCount": "number (서버 집계)"
      }
    },

    "purchase_history": {
      "table": "기존 주문 테이블",
      "typescript_interface": {
        "orderId": "string",
        "orderDate": "string",
        "productName": "string",
        "productModel": "string",
        "amount": "number",
        "deliveryStatus": "'PENDING' | 'SHIPPED' | 'DELIVERED'",
        "linkedTicketNo": "string | null"
      }
    },

    "consultation_log": {
      "table": "crm_call_memo (402K건) + tbnws_send_sms_result (2.6M건) 통합",
      "typescript_interface": {
        "consultationId": "number",
        "occurredAt": "string",
        "channel": "'PHONE' | 'KAKAO' | 'EMAIL' | 'SMS'",
        "summary": "string",
        "agentName": "string",
        "linkedTicketNo": "string | null",
        "durationSeconds": "number | null (통화만)"
      },
      "performance_note": "상담이력은 고객별 조회이므로 전체 402K건이 아닌 고객당 수십~수백 건. 서버 페이지네이션으로 충분."
    }
  },

