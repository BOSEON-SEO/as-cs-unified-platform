  "section4_component_architecture": {
    "title": "4. UI 컴포넌트 구조 (목표 설계)",

    "component_tree": [
      "CustomerPage (/1)",
      "├── CustomerSearchBar",
      "│   ├── PhoneInput (하이픈 자동 삽입, tel inputMode)",
      "│   ├── NameInput (선택적)",
      "│   ├── ScopeSelect (전체/A/S/구매/상담)",
      "│   └── SearchButton + ResetButton",
      "├── CustomerProfileCard",
      "│   ├── Avatar (이름 첫 2글자)",
      "│   ├── NameBadge (VIP, 정품등록 N건)",
      "│   ├── ContactInfo (phone, email, registeredAt)",
      "│   ├── KpiRow (구매액, 최근구매, A/S건수, 최근상담, 정품등록)",
      "│   └── ActionButtons ([편집], [+A/S접수]) — Can으로 RBAC",
      "├── CustomerTabs",
      "│   ├── TabBar (5 tabs with count badges)",
      "│   └── TabContent (lazy-loaded per active tab)",
      "│       ├── PurchaseHistoryTab → DataTable",
      "│       ├── AsHistoryTab → DataTable (row click → navigate)",
      "│       ├── ConsultationTab → DataTable + SidePanel",
      "│       ├── ProductRegistrationTab → Card grid",
      "│       └── MemoTab → Timeline + MemoForm",
      "├── MultipleResultModal (2건+ 검색 시 선택 모달)",
      "└── EmptyState (0건 → 신규등록 CTA)"
    ],

    "shared_components_needed": [
      "DataTable (columns, data, rowKey, sort, pagination)",
      "FilterBar (search + dropdowns + date)",
      "Pagination (server-side, 0-based)",
      "StatusBadge (VIP, 배송상태 등)",
      "Modal (복수 결과 선택)",
      "Tabs (5-tab container with count badges)",
      "SidePanel (상담 상세)",
      "KpiCard (구매액, A/S건수 등)",
      "Can (RBAC conditional render)"
    ],

    "state_management": {
      "search_state": "URL search params (?phone=010-...) — useSearchParams()",
      "active_tab": "useState (페이지 내 로컬)",
      "customer_data": "react-query: queryKey ['customer', 'phone', phone]",
      "tab_data": "react-query: queryKey ['customer', id, 'purchases'], ['customer', id, 'tickets'], etc. — tab 활성화 시 enabled=true",
      "memo_mutation": "react-query useMutation + invalidate ['customer', id, 'memos']"
    }
  },

  "section5_api_design": {
    "title": "5. API 엔드포인트 설계",

    "endpoints": [
      {
        "action": "고객 조회 (전화번호)",
        "method": "GET",
        "path": "/api/customers",
        "params": "phone (required), name (optional)",
        "response": "Customer | Customer[] (복수 결과 가능)",
        "rbac": "ALL (모든 인증 사용자)",
        "note": "1건: Customer 객체, 2건+: 배열, 0건: 빈 배열"
      },
      {
        "action": "구매 이력",
        "method": "GET",
        "path": "/api/customers/{id}/orders",
        "params": "page, size, sort",
        "response": "PageResponse<PurchaseHistory>",
        "rbac": "ALL"
      },
      {
        "action": "A/S 이력",
        "method": "GET",
        "path": "/api/customers/{id}/tickets",
        "params": "page, size",
        "response": "PageResponse<TicketSummary>",
        "rbac": "ALL"
      },
      {
        "action": "상담 이력",
        "method": "GET",
        "path": "/api/customers/{id}/consults",
        "params": "page, size, channel (optional)",
        "response": "PageResponse<ConsultationLog>",
        "rbac": "ALL"
      },
      {
        "action": "정품등록",
        "method": "GET",
        "path": "/api/customers/{id}/registrations",
        "response": "ProductRegistration[]",
        "rbac": "ALL",
        "note": "페이지네이션 불필요 (고객당 1~5건)"
      },
      {
        "action": "메모 조회",
        "method": "GET",
        "path": "/api/customers/{id}/memos",
        "response": "CustomerMemo[]",
        "rbac": "ALL"
      },
      {
        "action": "메모 작성",
        "method": "POST",
        "path": "/api/customers/{id}/memos",
        "body": "{ content: string }",
        "response": "CustomerMemo",
        "rbac": "CS_CX, TEAM_LEAD, ADMIN"
      },
      {
        "action": "신규 고객 등록",
        "method": "POST",
        "path": "/api/customers",
        "body": "{ phone, name, email? }",
        "response": "Customer",
        "rbac": "ALL"
      },
      {
        "action": "고객 정보 수정",
        "method": "PATCH",
        "path": "/api/customers/{id}",
        "body": "{ name?, email?, address? }",
        "response": "Customer",
        "rbac": "ADMIN only"
      }
    ],

    "total_endpoints": 9,

