  "section1_architecture": {
    "title": "(1) Email/SMS Sending Service Architecture",

    "overview_diagram": [
      "┌─────────────────────────────────────────────────────────────────────┐",
      "│                    Frontend (React)                                │",
      "│  ┌─────────────┐  ┌──────────────┐  ┌───────────────────────────┐ │",
      "│  │ 이메일 작성   │  │ SMS 작성     │  │ 시스템 자동 트리거         │ │",
      "│  │ 모달          │  │ 모달         │  │ (출고·회수·배정·종료 등)    │ │",
      "│  └──────┬───────┘  └──────┬───────┘  └────────────┬──────────────┘ │",
      "│         │                  │                       │               │",
      "│         └──────────────────┼───────────────────────┘               │",
      "│                           │                                       │",
      "│              POST /api/messages/send                               │",
      "└───────────────────────────┼───────────────────────────────────────┘",
      "                           │",
      "                           v",
      "┌───────────────────────────────────────────────────────────────────┐",
      "│                  Spring Boot (MessageService)                     │",
      "│                                                                   │",
      "│  1. Validate request (channel, recipient, content)                │",
      "│  2. INSERT as_mail_logs (status=PENDING)                          │",
      "│  3. Resolve channel adapter:                                      │",
      "│     ┌──────────┐  ┌──────────┐  ┌──────────┐                     │",
      "│     │EmailSender│  │SmsSender │  │AlimtalkSe│                     │",
      "│     │(SMTP)     │  │(Gateway) │  │nder(KT)  │                     │",
      "│     └─────┬─────┘  └─────┬────┘  └─────┬────┘                     │",
      "│           │              │              │                         │",
      "│  4. Send via external service                                     │",
      "│  5. UPDATE as_mail_logs (status=SENT/FAILED, error_detail)        │",
      "│  6. IF ticket_id: INSERT as_ticket_events (EMAIL_SENT/SMS_SENT)   │",
      "│  7. IF first outbound on ticket: INSERT FIRST_RESPONSE event      │",
      "│                                                                   │",
      "└───────────────────────────────────────────────────────────────────┘",
      "           │              │              │",
      "           v              v              v",
      "     ┌──────────┐  ┌──────────┐  ┌──────────┐",
      "     │SMTP Server│  │SMS GW    │  │알림톡 API │",
      "     │(existing) │  │(existing)│  │(KT/NHN)  │",
      "     └──────────┘  └──────────┘  └──────────┘"
    ],

