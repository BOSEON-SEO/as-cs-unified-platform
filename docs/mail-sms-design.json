    "retry_strategy": {
      "auto_retry": {
        "max_attempts": 3,
        "delays": ["immediate", "after 5 min", "after 30 min"],
        "implementation": "Spring @Retryable or custom retry with exponential backoff",
        "on_final_failure": "Status -> FAILED, error_detail recorded, visible in MailLog failed queue"
      },
      "manual_retry": {
        "trigger": "User clicks [재발송] button on MailLogPage",
        "behavior": "Creates NEW MailLog row (parent_log_id points to original). Does NOT modify original row.",
        "modify_and_retry": "User clicks [수신자 수정 후 재발송] -> change recipient -> send as new MailLog"
      },
      "alimtalk_fallback": {
        "behavior": "If Alimtalk fails (user not on KakaoTalk), automatically send same content as SMS",
        "logging": "Two MailLog rows: original ALIMTALK (FAILED) + fallback SMS (SENT). parent_log_id links them."
      }
    }
  },

  "section2_db_schema": {
    "title": "(2) MailLog Table Schema",

    "table": {
      "name": "as_mail_logs",
      "description": "Every email/SMS/alimtalk send attempt is logged here. Core domain entity per CLAUDE.md. Never deleted, only appended.",
      "ddl": [
        "CREATE TABLE as_mail_logs (",
        "  log_id           BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,",
        "  parent_log_id    BIGINT UNSIGNED NULL COMMENT 'FK to self. Non-null for resend/fallback, points to original send attempt',",
        "",
        "  -- Channel & recipient",
        "  channel          ENUM('EMAIL','SMS','ALIMTALK') NOT NULL,",
        "  recipient_type   ENUM('CUSTOMER','ENGINEER','DRIVER','TEAM_LEAD','SYSTEM') NOT NULL DEFAULT 'CUSTOMER',",
        "  recipient_name   VARCHAR(100) NULL,",
        "  recipient_email  VARCHAR(200) NULL COMMENT 'Non-null when channel=EMAIL',",
        "  recipient_phone  VARCHAR(20) NULL COMMENT 'Non-null when channel=SMS or ALIMTALK',",
        "",
        "  -- Content",
        "  subject          VARCHAR(300) NULL COMMENT 'Email subject. NULL for SMS/ALIMTALK',",
        "  content_text     TEXT NOT NULL COMMENT 'Plain text body (SMS content or email text fallback)',",
        "  content_html     MEDIUMTEXT NULL COMMENT 'HTML body for EMAIL. NULL for SMS/ALIMTALK',",
        "  template_id      VARCHAR(50) NULL COMMENT 'Template ID used (TPL_* or ALT_*). NULL for freeform',",
        "  template_params  JSON NULL COMMENT 'Key-value pairs substituted into template',",
        "",
        "  -- Context",
        "  ticket_id        BIGINT UNSIGNED NULL COMMENT 'FK to as_tickets. NULL for non-ticket messages',",
        "  ticket_no        VARCHAR(20) NULL COMMENT 'Denormalized ticket number for quick display',",
        "  trigger_type     ENUM('MANUAL','SYSTEM_AUTO','RESEND','ALIMTALK_FALLBACK') NOT NULL DEFAULT 'MANUAL',",
        "",
        "  -- Delivery status",
        "  status           ENUM('PENDING','SENT','DELIVERED','FAILED','CANCELLED') NOT NULL DEFAULT 'PENDING',",
        "  error_code       VARCHAR(50) NULL COMMENT 'Gateway error code (e.g., R-401, SMTP 550)',",
        "  error_detail     VARCHAR(500) NULL COMMENT 'Human-readable error message',",
        "  retry_count      TINYINT UNSIGNED NOT NULL DEFAULT 0,",
        "  max_retries      TINYINT UNSIGNED NOT NULL DEFAULT 3,",
        "",
        "  -- External references",
        "  external_msg_id  VARCHAR(100) NULL COMMENT 'Message ID from SMS gateway or SMTP server',",
        "",
        "  -- Who sent it",
        "  sent_by          BIGINT UNSIGNED NULL COMMENT 'FK to users. NULL for SYSTEM_AUTO',",
        "  sent_by_name     VARCHAR(50) NULL,",
        "",
        "  -- Timestamps",
        "  created_at       DATETIME(3) NOT NULL DEFAULT CURRENT_TIMESTAMP(3),",
        "  sent_at          DATETIME(3) NULL COMMENT 'When actually sent to gateway',",
        "  delivered_at     DATETIME(3) NULL COMMENT 'Delivery receipt timestamp (if available)',",
        "  failed_at        DATETIME(3) NULL,",
        "",
        "  -- Indexes",
        "  INDEX idx_ml_ticket (ticket_id, created_at),",
        "  INDEX idx_ml_channel (channel, status, created_at),",
        "  INDEX idx_ml_recipient_email (recipient_email, created_at),",
        "  INDEX idx_ml_recipient_phone (recipient_phone, created_at),",
        "  INDEX idx_ml_status (status, created_at),",
        "  INDEX idx_ml_sent_by (sent_by, created_at),",
        "  INDEX idx_ml_parent (parent_log_id),",
        "",
        "  -- Foreign keys",
        "  CONSTRAINT fk_ml_ticket FOREIGN KEY (ticket_id) REFERENCES as_tickets(ticket_id),",
        "  CONSTRAINT fk_ml_sender FOREIGN KEY (sent_by) REFERENCES users(id),",
        "  CONSTRAINT fk_ml_parent FOREIGN KEY (parent_log_id) REFERENCES as_mail_logs(log_id)",
        ") ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;"
      ]
    },

    "status_state_machine": {
      "states": [
        { "value": "PENDING",   "label": "대기",     "badge": "b-slate",  "description": "MailLog created, send not yet attempted" },
        { "value": "SENT",      "label": "성공",     "badge": "b-green",  "description": "Successfully sent to gateway (accepted)" },
        { "value": "DELIVERED", "label": "수신확인", "badge": "b-green",  "description": "Delivery receipt confirmed (email/alimtalk only)" },
        { "value": "FAILED",   "label": "실패",     "badge": "b-red",    "description": "All retry attempts exhausted" },
        { "value": "CANCELLED","label": "취소",     "badge": "b-amber",  "description": "Cancelled before sending (rare)" }
      ],
      "transitions": [
        { "from": "PENDING",   "to": "SENT",      "trigger": "Gateway returns success" },
        { "from": "PENDING",   "to": "PENDING",   "trigger": "Gateway returns error, retry_count < max_retries (increment retry_count, schedule next attempt)" },
        { "from": "PENDING",   "to": "FAILED",    "trigger": "Gateway returns error, retry_count >= max_retries" },
        { "from": "PENDING",   "to": "CANCELLED", "trigger": "Manual cancel before send" },
        { "from": "SENT",      "to": "DELIVERED", "trigger": "Delivery receipt webhook (optional, channel-dependent)" },
        { "from": "SENT",      "to": "FAILED",    "trigger": "Bounce notification (email) or delivery failure callback (SMS)" }
      ]
    },

    "parent_log_id_usage": {
      "resend": "When user resends a failed message: new MailLog row with parent_log_id = original log_id. Original stays FAILED.",
      "alimtalk_fallback": "When alimtalk fails and SMS fallback fires: SMS row has parent_log_id = alimtalk row's log_id.",
      "chain": "Multiple resends create a chain: original(FAILED) <- resend1(FAILED) <- resend2(SENT). Query: SELECT * FROM as_mail_logs WHERE log_id = :id OR parent_log_id = :id"
    }
  },

  "section3_auto_logging": {
    "title": "(3) Auto-Logging Mechanism on Send Completion",

    "principle": "Every message send operation MUST create a MailLog record BEFORE attempting delivery. The log is created in PENDING status, then updated to SENT/FAILED after delivery. This guarantees no send can happen without a log, per CLAUDE.md domain rule.",

    "sequence_diagram": [
      "Frontend                    Spring Boot                     External Gateway",
      "   |                            |                               |",
      "   | POST /api/messages/send    |                               |",
      "   | { channel, recipient,      |                               |",
      "   |   content, ticketId? }     |                               |",
      "   |--------------------------->|                               |",
      "   |                            |                               |",
      "   |                    [1] Validate request                    |",
      "   |                    [2] INSERT as_mail_logs                 |",
      "   |                        (status=PENDING, retry=0)          |",
      "   |                    [3] Resolve channel adapter             |",
      "   |                            |                               |",
      "   |                            |--- send(message) ----------->|",
      "   |                            |                               |",
      "   |                            |<-- 200 OK / error ------------|",
      "   |                            |                               |",
      "   |                    [4a] If success:                        |",
      "   |                        UPDATE as_mail_logs                 |",
      "   |                          SET status=SENT,                  |",
      "   |                              sent_at=NOW(),                |",
      "   |                              external_msg_id=xxx           |",
      "   |                                                            |",
      "   |                    [4b] If error + retry_count < max:      |",
      "   |                        UPDATE retry_count++                 |",
      "   |                        Schedule retry (5min / 30min)       |",
      "   |                                                            |",
      "   |                    [4c] If error + retry_count >= max:     |",
      "   |                        UPDATE status=FAILED,               |",
      "   |                          error_code, error_detail,         |",
      "   |                          failed_at=NOW()                   |",
      "   |                                                            |",
      "   |                    [5] IF ticket_id IS NOT NULL:           |",
      "   |                        INSERT as_ticket_events             |",
      "   |                          (EMAIL_SENT or SMS_SENT)          |",
      "   |                          payload: { mailLogId, subject }   |",
      "   |                                                            |",
      "   |                    [6] FIRST_RESPONSE auto-detect:        |",
      "   |                        IF this is the first outbound      |",
      "   |                        comm on this ticket:                |",
      "   |                        INSERT as_ticket_events             |",
      "   |                          (FIRST_RESPONSE)                  |",
      "   |                                                            |",
      "   |<--- 200 { logId, status } --|                              |",
      "   |                            |                               |"
    ],

    "spring_implementation": {
      "service_class": "MessageService",

      "send_method_pseudocode": [
        "@Transactional",
        "public SendResult send(SendRequest request) {",
        "",
        "  // 1. Validate",
        "  validateRequest(request);",
        "",
        "  // 2. Create MailLog FIRST (before any send attempt)",
        "  MailLog log = MailLog.builder()",
        "    .channel(request.channel)",
        "    .recipientType(request.recipientType)",
        "    .recipientName(request.recipientName)",
        "    .recipientEmail(request.recipientEmail)",
        "    .recipientPhone(request.recipientPhone)",
        "    .subject(request.subject)",
        "    .contentText(request.contentText)",
        "    .contentHtml(request.contentHtml)",
        "    .templateId(request.templateId)",
        "    .templateParams(request.templateParams)",
        "    .ticketId(request.ticketId)",
        "    .ticketNo(request.ticketNo)",
        "    .triggerType(request.triggerType)",
        "    .sentBy(request.sentBy)",
        "    .sentByName(request.sentByName)",
        "    .status(MailLogStatus.PENDING)",
        "    .build();",
        "  log = mailLogRepository.save(log);  // INSERT with PENDING",
        "",
        "  // 3. Attempt send via channel adapter",
        "  try {",
        "    ChannelAdapter adapter = adapterFactory.get(request.channel);",
        "    ExternalResult result = adapter.send(log);",
        "",
        "    // 4a. Success",
        "    log.setStatus(MailLogStatus.SENT);",
        "    log.setSentAt(Instant.now());",
        "    log.setExternalMsgId(result.messageId());",
        "    mailLogRepository.save(log);",
        "",
        "  } catch (SendException e) {",
        "    log.setRetryCount(log.getRetryCount() + 1);",
        "    if (log.getRetryCount() < log.getMaxRetries()) {",
        "      // 4b. Retry scheduled",
        "      retryScheduler.schedule(log.getLogId(), retryDelay(log.getRetryCount()));",
        "    } else {",
        "      // 4c. Final failure",
        "      log.setStatus(MailLogStatus.FAILED);",
        "      log.setErrorCode(e.getCode());",
        "      log.setErrorDetail(e.getMessage());",
        "      log.setFailedAt(Instant.now());",
        "    }",
        "    mailLogRepository.save(log);",
        "  }",
        "",
        "  // 5. Link to ticket event (if ticket-scoped)",
        "  if (log.getTicketId() != null && log.getStatus() == MailLogStatus.SENT) {",
        "    ticketEventService.logCommunication(log);",
        "  }",
        "",
        "  return SendResult.from(log);",
        "}"
      ],

      "ticket_event_linking": {
        "method": "ticketEventService.logCommunication(MailLog log)",
        "logic": [
          "1. Determine event_type based on channel: EMAIL->EMAIL_SENT, SMS/ALIMTALK->SMS_SENT",
          "2. Build payload: { mailLogId: log.logId, subject: log.subject }",
          "3. INSERT as_ticket_events (ticket_id, event_type, actor_id=log.sentBy, payload)",
          "4. FIRST_RESPONSE auto-detect:",
          "     SELECT COUNT(*) FROM as_ticket_events",
          "     WHERE ticket_id = log.ticketId",
          "       AND event_type IN ('EMAIL_SENT','SMS_SENT','PHONE_CALL_LOGGED')",
          "       AND actor_role != 'CUSTOMER'",
          "       AND event_id < current_event_id",
          "     If count == 0:",
          "       INSERT as_ticket_events (FIRST_RESPONSE, payload={channel, messageId=log.logId})"
        ]
      },

      "system_auto_trigger": {
        "implementation": "@TransactionalEventListener on TicketEvent domain events",
        "example": [
          "@TransactionalEventListener",
          "public void onTicketCreated(TicketCreatedEvent event) {",
          "  Customer customer = customerService.getById(event.customerId());",
          "  SendRequest req = SendRequest.systemAuto()",
          "    .channel(Channel.ALIMTALK)",
          "    .recipientPhone(customer.phone())",
          "    .templateId('ALT_AS_RECEIVED')",
          "    .templateParams(Map.of('ticketNo', event.ticketNo(), 'productModel', event.productModel()))",
          "    .ticketId(event.ticketId())",
          "    .build();",
          "  messageService.send(req);",
          "}"
        ]
      }
    },

    "doD_verification": {
      "rule": "이메일·SMS 발송 시 MailLog 자동 생성 확인 (CLAUDE.md DoD 패턴)",
      "verification_method": [
        "Unit test: Every call to MessageService.send() produces exactly 1 MailLog row",
        "Integration test: POST /api/messages/send -> verify MailLog row exists in DB",
        "Constraint: MailLog INSERT happens BEFORE gateway call (not after). If gateway crashes, MailLog still exists with PENDING status.",
        "Negative test: Directly calling SMTP/SMS adapter without MessageService is prohibited. Adapter constructors are package-private, only injectable via MessageService."
      ]
    }
  },

  "api_endpoints": [
    {
      "method": "POST",
      "path": "/api/messages/send",
      "description": "Send email/SMS/alimtalk + auto-create MailLog + auto-create TicketEvent",
      "auth": "AS_ENGINEER, CS_CX, TEAM_LEAD, ADMIN",
      "request": {
        "channel": "EMAIL | SMS | ALIMTALK",
        "recipientEmail": "string (required for EMAIL)",
        "recipientPhone": "string (required for SMS/ALIMTALK)",
        "recipientName": "string (optional)",
        "subject": "string (required for EMAIL, optional for SMS/ALIMTALK)",
        "contentText": "string (required)",
        "contentHtml": "string (optional, EMAIL only)",
