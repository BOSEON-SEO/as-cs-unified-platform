  "section3_backend_frontend": {
    "title": "(3) Backend CSV Generation & Frontend Download",

    "backend_csv_generation": {
      "approach": "Server-side streaming CSV generation",
      "rationale": [
        "Data can be 100K+ rows (mail logs 2.6M, tickets 10K+) — client-side generation would crash browser",
        "Server applies RBAC filters (TEAM_LEAD sees team only, ADMIN sees all)",
        "PII masking for non-ADMIN users (customer phone partially masked in CSV)",
        "Consistent encoding (UTF-8 BOM for Korean Excel compatibility)"
      ],

      "spring_implementation": {
        "controller": "ExportController",
        "pattern": "StreamingResponseBody for large datasets",

        "code_structure": [
          "@GetMapping('/api/export/tickets')",
          "@PreAuthorize('hasAnyRole(\"TEAM_LEAD\",\"ADMIN\")')",
          "public ResponseEntity<StreamingResponseBody> exportTickets(",
          "    @RequestParam String from,",
          "    @RequestParam String to,",
          "    @RequestParam(required=false) List<String> status,",
          "    @RequestParam(required=false) String assigneeId,",
          "    @RequestParam String format  // csv, xlsx",
          ") {",
          "    String filename = 'AS_tickets_' + from + '_' + to + '_' + timestamp + '.' + format;",
          "",
          "    StreamingResponseBody body = outputStream -> {",
          "        if (format.equals('csv')) {",
          "            // Write UTF-8 BOM",
          "            outputStream.write(new byte[]{(byte)0xEF, (byte)0xBB, (byte)0xBF});",
          "",
          "            // Write header row",
          "            csvWriter.writeHeader(outputStream, TICKET_COLUMNS);",
          "",
          "            // Stream data in chunks (1000 rows per batch)",
          "            ticketRepository.streamByFilters(from, to, status, assigneeId)",
          "                .forEach(ticket -> csvWriter.writeRow(outputStream, ticket));",
          "        } else if (format.equals('xlsx')) {",
          "            // Apache POI SXSSFWorkbook (streaming, low memory)",
          "            excelService.writeTickets(outputStream, from, to, status, assigneeId);",
          "        }",
          "    };",
          "",
          "    return ResponseEntity.ok()",
          "        .header(HttpHeaders.CONTENT_DISPOSITION, 'attachment; filename=\"' + filename + '\"')",
          "        .contentType(format.equals('csv')",
          "            ? MediaType.parseMediaType('text/csv; charset=UTF-8')",
          "            : MediaType.parseMediaType('application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'))",
          "        .body(body);",
          "}"
        ],

        "streaming_detail": {
          "csv": "Write rows directly to OutputStream via BufferedWriter. No intermediate List<>.",
          "xlsx": "Apache POI SXSSFWorkbook with window size 100 (keeps only 100 rows in memory, flushes older rows to temp file)",
          "pdf": "iText or OpenPDF. Max 500 rows. Table layout with company header."
        },

        "pii_handling": {
          "ADMIN": "Full data (no masking)",
          "TEAM_LEAD": "Customer phone: last 4 digits only (***-****-5678). Name: full.",
          "AS_ENGINEER": "Cannot download CSV (page not accessible)",
          "implementation": "ExportService checks SecurityContext role and applies masking function per row"
        }
      }
    },

    "frontend_download": {
      "approach": "Fetch as blob + trigger browser download",

      "react_implementation": {
        "hook": "useExportDownload (src/hooks/useExportDownload.ts)",
        "code_example": [
          "function useExportDownload() {",
          "  const [isDownloading, setIsDownloading] = useState(false);",
          "",
          "  async function download(endpoint: string, params: Record<string,string>, format: 'csv' | 'xlsx') {",
          "    setIsDownloading(true);",
          "    try {",
          "      const queryString = new URLSearchParams({ ...params, format }).toString();",
          "      const response = await apiClient.get(`${endpoint}?${queryString}`, {",
          "        responseType: 'blob',",
          "        timeout: 120_000,  // 2 min for large exports",
          "      });",
          "",
          "      // Extract filename from Content-Disposition header",
          "      const disposition = response.headers['content-disposition'] || '';",
          "      const filenameMatch = disposition.match(/filename=\"(.+)\"/);",
          "      const filename = filenameMatch?.[1] ?? `export_${Date.now()}.${format}`;",
          "",
          "      // Create download link",
          "      const url = window.URL.createObjectURL(response.data);",
          "      const link = document.createElement('a');",
          "      link.href = url;",
          "      link.download = filename;",
          "      document.body.appendChild(link);",
          "      link.click();",
          "      link.remove();",
          "      window.URL.revokeObjectURL(url);",
          "",
          "      toast.success(`${filename} 다운로드 완료`);",
          "    } catch (error) {",
          "      toast.error('다운로드에 실패했습니다. 다시 시도해 주세요.');",
          "    } finally {",
          "      setIsDownloading(false);",
          "    }",
          "  }",
          "",
          "  return { download, isDownloading };",
          "}"
        ],

        "electron_handling": {
          "note": "In Electron, blob download works the same way via Chromium. No special IPC needed.",
          "file_dialog": "Electron will show native save-as dialog automatically on blob download."
        },

        "ui_buttons": {
