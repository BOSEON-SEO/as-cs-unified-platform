        { "key": "productModel", "header": "제품", "width": "80px", "sortable": true },
        { "key": "ticketTypeLabel", "header": "유형", "width": "70px", "sortable": false, "render": "StatusBadge (REPAIR=blue, EXCHANGE=amber, RETURN=red)" },
        { "key": "assigneeName", "header": "담당", "width": "80px", "sortable": true, "render": "text, null → '미배정' (muted)" },
        { "key": "statusLabel", "header": "상태", "width": "80px", "sortable": true, "render": "StatusBadge (8 status colors from TICKET_STATUS_LABELS)" },
        { "key": "createdAt", "header": "접수일", "width": "100px", "sortable": true, "render": "YYYY-MM-DD" },
        { "key": "elapsedDays", "header": "경과", "width": "60px", "sortable": true, "render": "{N}일. >=14 → red, >=7 → amber" }
