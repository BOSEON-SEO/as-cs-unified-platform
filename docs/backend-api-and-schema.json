            { "userId": 101, "enabled": true },
            { "userId": 102, "enabled": true },
            { "userId": 103, "enabled": false }
          ]
        },
        "validation": {
          "mode": "Must be one of ROUND_ROBIN, LEAST_LOADED, CAPABILITY_MATCH",
          "maxPerAssignee": "1..50, integer",
