  "section3_shipment": {
    "title": "(3) Shipment State Machine",

    "db_schema": {
      "table_shipments": {
        "name": "as_shipments",
        "ddl": [
          "CREATE TABLE as_shipments (",
          "  shipment_id     BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,",
          "  ticket_id       BIGINT UNSIGNED NOT NULL,",
          "  recipient_name  VARCHAR(100) NOT NULL,",
          "  recipient_phone VARCHAR(20) NOT NULL,",
          "  address         VARCHAR(500) NOT NULL,",
          "  shipment_type   ENUM('REPAIRED','EXCHANGE_NEW','REFURBISHED') NOT NULL,",
          "  carrier         VARCHAR(50) NOT NULL,",
          "  tracking_no     VARCHAR(50) NULL,",
          "  status          ENUM('PREPARING','DISPATCHED','DELIVERED','CANCELLED') NOT NULL DEFAULT 'PREPARING',",
          "  cx_handover     ENUM('NOT_REQUIRED','PENDING','CONFIRMED') NOT NULL DEFAULT 'NOT_REQUIRED',",
          "  note            VARCHAR(500) NULL,",
          "  created_by      BIGINT UNSIGNED NOT NULL,",
          "  created_at      DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,",
          "  dispatched_at   DATETIME NULL,",
          "  delivered_at    DATETIME NULL,",
          "  cancelled_at    DATETIME NULL,",
          "  cancel_reason   VARCHAR(500) NULL,",
          "  updated_at      DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,",
          "  INDEX idx_ship_ticket (ticket_id),",
          "  INDEX idx_ship_status (status, created_at),",
          "  INDEX idx_ship_cx (cx_handover),",
          "  INDEX idx_ship_tracking (carrier, tracking_no),",
          "  CONSTRAINT fk_ship_ticket FOREIGN KEY (ticket_id) REFERENCES as_tickets(ticket_id),",
          "  CONSTRAINT fk_ship_creator FOREIGN KEY (created_by) REFERENCES users(id)",
          ") ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;"
        ]
      },
      "table_recalls": {
        "name": "as_recalls",
        "ddl": [
          "CREATE TABLE as_recalls (",
          "  recall_id       BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,",
          "  ticket_id       BIGINT UNSIGNED NOT NULL,",
          "  customer_name   VARCHAR(100) NOT NULL,",
          "  customer_phone  VARCHAR(20) NOT NULL,",
          "  address         VARCHAR(500) NOT NULL,",
          "  product_model   VARCHAR(100) NOT NULL,",
          "  recall_method   ENUM('DRIVER_DIRECT','COURIER') NOT NULL,",
          "  driver_id       BIGINT UNSIGNED NULL,",
          "  pickup_date     DATE NOT NULL,",
          "  status          ENUM('REQUESTED','ASSIGNED','COMPLETED','CANCELLED') NOT NULL DEFAULT 'REQUESTED',",
          "  condition_note  VARCHAR(500) NULL COMMENT 'Filled on completion',",
          "  grade           ENUM('A','B','C') NULL COMMENT 'Inspection grade on completion',",
          "  note            VARCHAR(500) NULL,",
          "  cancel_reason   VARCHAR(500) NULL,",
          "  created_by      BIGINT UNSIGNED NOT NULL,",
          "  created_at      DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,",
          "  completed_at    DATETIME NULL,",
          "  updated_at      DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,",
          "  INDEX idx_recall_ticket (ticket_id),",
          "  INDEX idx_recall_status (status, pickup_date),",
          "  INDEX idx_recall_driver (driver_id, status),",
          "  INDEX idx_recall_overdue (status, pickup_date),",
          "  CONSTRAINT fk_recall_ticket FOREIGN KEY (ticket_id) REFERENCES as_tickets(ticket_id),",
          "  CONSTRAINT fk_recall_creator FOREIGN KEY (created_by) REFERENCES users(id),",
          "  CONSTRAINT fk_recall_driver FOREIGN KEY (driver_id) REFERENCES as_drivers(driver_id)",
          ") ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;"
        ]
      },
      "table_drivers": {
        "name": "as_drivers",
        "ddl": [
          "CREATE TABLE as_drivers (",
          "  driver_id       BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,",
          "  name            VARCHAR(50) NOT NULL,",
          "  phone           VARCHAR(20) NOT NULL,",
          "  region          VARCHAR(100) NULL,",
          "  max_capacity    INT UNSIGNED NOT NULL DEFAULT 10,",
          "  available       BOOLEAN NOT NULL DEFAULT TRUE,",
          "  created_at      DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,",
          "  updated_at      DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP",
          ") ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;"
        ]
      }
    },

    "shipment_state_machine": {
      "states": {
        "PREPARING":  { "description": "Created, no tracking number yet", "badge": "b-slate" },
        "DISPATCHED": { "description": "Tracking number entered", "badge": "b-blue" },
        "DELIVERED":  { "description": "Carrier confirms delivery or manual mark", "badge": "b-green" },
        "CANCELLED":  { "description": "Cancelled before delivery", "badge": "b-red" }
      },
      "transitions": [
        {
          "from": "PREPARING", "to": "DISPATCHED",
          "trigger": "tracking_no is set (on create with tracking OR on update adding tracking)",
          "auto": true,
          "guard": "tracking_no must be non-empty string, digits only",
          "db_update": "SET status='DISPATCHED', dispatched_at=NOW(), tracking_no=:trackingNo",
          "event": "SHIPMENT_DISPATCHED"
        },
        {
          "from": "PREPARING", "to": "CANCELLED",
          "trigger": "Manual cancel",
          "guard": "cancel_reason required (>=5 chars)",
          "db_update": "SET status='CANCELLED', cancelled_at=NOW(), cancel_reason=:reason",
          "event": "STATUS_CHANGED(PREPARING->CANCELLED)"
        },
        {
          "from": "DISPATCHED", "to": "DELIVERED",
          "trigger": "Carrier API polling OR manual mark",
          "guard": "none",
          "db_update": "SET status='DELIVERED', delivered_at=NOW()",
          "event": "SHIPMENT_DELIVERED"
        },
        {
          "from": "DISPATCHED", "to": "CANCELLED",
          "trigger": "Manual cancel (rare, package recalled from carrier)",
          "guard": "cancel_reason required",
          "db_update": "SET status='CANCELLED', cancelled_at=NOW(), cancel_reason=:reason",
          "event": "STATUS_CHANGED(DISPATCHED->CANCELLED)"
        }
      ],
      "invalid_transitions": [
        "DELIVERED -> any (terminal state)",
        "CANCELLED -> any (terminal state)",
        "PREPARING -> DELIVERED (must go through DISPATCHED)",
        "DISPATCHED -> PREPARING (no backward)"
      ]
    },

    "recall_state_machine": {
      "states": {
        "REQUESTED":  { "description": "Created, no driver assigned", "badge": "b-red" },
        "ASSIGNED":   { "description": "Driver assigned, SMS sent", "badge": "b-blue" },
        "COMPLETED":  { "description": "Driver confirmed pickup", "badge": "b-green" },
        "CANCELLED":  { "description": "Cancelled", "badge": "b-slate" }
      },
      "transitions": [
        {
          "from": "REQUESTED", "to": "ASSIGNED",
          "trigger": "driver_id set (on create with driver OR on update adding driver)",
          "guard": "driver_id must be valid, driver.available=true, driver.current < driver.max_capacity",
          "db_update": "SET status='ASSIGNED', driver_id=:driverId",
          "event": "PICKUP_SCHEDULED",
          "side_effect": "Send SMS to driver via MailLog"
        },
        {
          "from": "ASSIGNED", "to": "COMPLETED",
          "trigger": "Manual completion confirmation",
          "guard": "condition_note required, grade required (A/B/C)",
          "db_update": "SET status='COMPLETED', completed_at=NOW(), condition_note=:note, grade=:grade",
          "event": "PICKUP_COMPLETED"
        },
        {
          "from": "ASSIGNED", "to": "REQUESTED",
          "trigger": "Driver reassignment (unlink current driver)",
          "guard": "reason required (stored in recall note append)",
          "db_update": "SET status='REQUESTED', driver_id=NULL",
          "event": "STATUS_CHANGED(ASSIGNED->REQUESTED)"
        },
        {
          "from": "REQUESTED", "to": "CANCELLED",
          "trigger": "Manual cancel",
          "guard": "cancel_reason required",
          "db_update": "SET status='CANCELLED', cancel_reason=:reason"
        },
        {
          "from": "ASSIGNED", "to": "CANCELLED",
          "trigger": "Manual cancel",
          "guard": "cancel_reason required",
          "db_update": "SET status='CANCELLED', cancel_reason=:reason"
        }
      ],
      "overdue_detection": {
        "query": "SELECT * FROM as_recalls WHERE status IN ('REQUESTED','ASSIGNED') AND pickup_date < CURDATE()",
        "schedule": "Spring @Scheduled cron: 0 0 9 * * MON-FRI (daily 09:00 weekdays)",
        "action": "Notify TEAM_LEAD via system notification"
      }
    },

