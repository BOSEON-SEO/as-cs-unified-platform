        "description": "Get current auto-assignment configuration + pool + KPI stats",
        "auth": "TEAM_LEAD, ADMIN",
        "response_200": {
          "enabled": true,
          "mode": "ROUND_ROBIN",
          "maxPerAssignee": 20,
