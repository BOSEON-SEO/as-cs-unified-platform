  "section2_cost_entry": {
    "title": "(2) CostEntry 3-Axis CRUD",

    "db_schema": {
      "table_cost_entries": {
        "name": "as_cost_entries",
        "ddl": [
          "CREATE TABLE as_cost_entries (",
          "  cost_id         BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,",
          "  ticket_id       BIGINT UNSIGNED NOT NULL,",
          "  axis            ENUM('OUR_EXPENSE','CUSTOMER_PAYMENT','VENDOR_COMPENSATION') NOT NULL,",
          "  category        VARCHAR(50) NOT NULL,",
          "  amount          INT NOT NULL DEFAULT 0 COMMENT 'Amount in KRW (won), always positive',",
          "  description     VARCHAR(500) NULL,",
          "  receipt_url     VARCHAR(500) NULL COMMENT 'S3/storage path for receipt file',",
          "  status          ENUM('PENDING','APPROVED','REJECTED') NOT NULL DEFAULT 'PENDING',",
          "  rejection_reason VARCHAR(500) NULL,",
          "  created_by      BIGINT UNSIGNED NOT NULL,",
          "  approved_by     BIGINT UNSIGNED NULL,",
          "  created_at      DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,",
          "  updated_at      DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,",
          "  INDEX idx_cost_ticket (ticket_id),",
          "  INDEX idx_cost_axis (axis, created_at),",
          "  INDEX idx_cost_status (status, created_at),",
          "  INDEX idx_cost_created_by (created_by),",
          "  CONSTRAINT fk_cost_ticket FOREIGN KEY (ticket_id) REFERENCES as_tickets(ticket_id),",
          "  CONSTRAINT fk_cost_creator FOREIGN KEY (created_by) REFERENCES users(id),",
          "  CONSTRAINT fk_cost_approver FOREIGN KEY (approved_by) REFERENCES users(id),",
          "  CONSTRAINT chk_amount_positive CHECK (amount >= 0)",
          ") ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;"
        ]
      }
    },

    "category_validation": {
      "description": "category must match its axis. Server rejects mismatched axis+category.",
      "allowed_categories": {
        "OUR_EXPENSE":           ["PARTS", "SHIPPING", "REPAIR_LABOR", "OTHER_EXPENSE"],
        "CUSTOMER_PAYMENT":      ["REPAIR_CHARGE", "SHIPPING_CHARGE", "OTHER_PAYMENT"],
        "VENDOR_COMPENSATION":   ["CLAIM_COMPENSATION", "WARRANTY_REPAIR_REIMBURSEMENT", "OTHER_COMPENSATION"]
      },
      "category_labels_ko": {
        "PARTS": "부품비",
        "SHIPPING": "택배비",
        "REPAIR_LABOR": "수리비",
        "OTHER_EXPENSE": "기타 지출",
        "REPAIR_CHARGE": "수리비 청구",
        "SHIPPING_CHARGE": "택배비 청구",
        "OTHER_PAYMENT": "기타 수납",
        "CLAIM_COMPENSATION": "클레임 보상금",
        "WARRANTY_REPAIR_REIMBURSEMENT": "무상 수리 보전",
        "OTHER_COMPENSATION": "기타 보상"
      }
    },

    "net_cost_formula": {
      "formula": "netCost = SUM(CUSTOMER_PAYMENT) + SUM(VENDOR_COMPENSATION) - SUM(OUR_EXPENSE)",
      "sign_convention": "positive = net gain, negative = net loss",
      "note": "Computed dynamically on read, NOT stored in DB. Only APPROVED entries included in aggregation."
    },

    "approval_state_machine": {
      "states": ["PENDING", "APPROVED", "REJECTED"],
      "transitions": [
        { "from": "PENDING",  "to": "APPROVED", "actor": "TEAM_LEAD | ADMIN", "guard": "none",                           "event": "COST_APPROVED" },
        { "from": "PENDING",  "to": "REJECTED", "actor": "TEAM_LEAD | ADMIN", "guard": "rejection_reason required (>=5 chars)", "event": "COST_UPDATED (status change)" },
        { "from": "REJECTED", "to": "PENDING",  "actor": "original creator",  "guard": "amount or category must differ from rejected version", "event": "COST_UPDATED (re-submit)" }
      ],
      "rules": [
        "APPROVED is terminal for that entry (no further transitions)",
        "Only ADMIN can DELETE a cost entry (hard delete, for corrections)",
        "APPROVED entries are included in monthly summary aggregation",
        "PENDING and REJECTED entries are excluded from summary"
      ]
    },

    "api_endpoints": [
      {
        "endpoint": "POST /api/tickets/{ticketId}/costs",
        "description": "Create a new cost entry for a ticket",
        "auth": "AS_ENGINEER (own ticket), ADMIN",
        "request_body": {
          "axis": "OUR_EXPENSE",
          "category": "PARTS",
          "amount": 15000,
          "description": "좌측 드라이버 유닛 교체",
          "receiptFile": "(multipart file, optional)"
        },
        "validation": {
          "axis": "Required, must be one of the 3 axis enum values",
          "category": "Required, must be in the allowed list for the given axis",
          "amount": "Required, integer >= 0, max 99999999",
          "description": "Optional, maxLength 500",
          "receiptFile": "Optional, max 10MB, types: jpg/png/pdf",
          "ticket": "Must exist, current user must be the assignee OR have ADMIN role",
          "ticket.status": "Must be IN_PROGRESS, COST_ENTERED, or SHIPPING (steps 3-5)"
        },
        "response_201": {
          "costId": 501,
          "ticketId": 2641,
          "axis": "OUR_EXPENSE",
          "category": "PARTS",
          "categoryLabel": "부품비",
          "amount": 15000,
          "description": "좌측 드라이버 유닛 교체",
          "receiptUrl": "/files/receipts/501_receipt.jpg",
          "status": "PENDING",
          "rejectionReason": null,
          "createdBy": 101,
          "createdByName": "박수리",
          "approvedBy": null,
          "createdAt": "2026-04-29T11:30:00.000Z",
          "updatedAt": "2026-04-29T11:30:00.000Z"
        },
        "side_effects": [
          "INSERT as_ticket_events (COST_ADDED, payload={axis, amount, category})"
        ],
        "response_400_examples": [
          { "code": "INVALID_CATEGORY", "message": "Category PARTS is not valid for axis CUSTOMER_PAYMENT" },
          { "code": "INVALID_AMOUNT", "message": "Amount must be a non-negative integer" }
        ]
      },
      {
        "endpoint": "GET /api/tickets/{ticketId}/costs",
        "description": "List all cost entries for a ticket",
        "auth": "AS_ENGINEER (own ticket), TEAM_LEAD, ADMIN",
        "response_200": {
          "entries": [
            {
              "costId": 501,
              "axis": "OUR_EXPENSE",
              "category": "PARTS",
