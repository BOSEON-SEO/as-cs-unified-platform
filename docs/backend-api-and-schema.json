            "rejectedCount": 0
          }
        }
      },
      {
        "endpoint": "PATCH /api/tickets/{ticketId}/costs/{costId}",
        "description": "Update cost entry (edit fields OR approve/reject)",
        "auth": "Creator (edit), TEAM_LEAD (approve/reject), ADMIN (all)",
        "request_body_edit": {
          "axis": "OUR_EXPENSE",
          "category": "SHIPPING",
          "amount": 5000,
          "description": "택배비 수정"
        },
        "request_body_approve": {
          "status": "APPROVED"
        },
        "request_body_reject": {
          "status": "REJECTED",
          "rejectionReason": "영수증 첨부 필요합니다"
        },
        "validation_edit": {
          "who": "Only the original creator can edit, and only when status is PENDING or REJECTED",
          "axis+category": "Same cross-validation as create",
          "amount": "Same rules as create"
        },
        "validation_approve": {
          "who": "TEAM_LEAD or ADMIN only",
          "status": "Current status must be PENDING"
        },
        "validation_reject": {
          "who": "TEAM_LEAD or ADMIN only",
          "status": "Current status must be PENDING",
          "rejectionReason": "Required, minLength 5"
        },
        "response_200": "Updated CostEntry object",
        "response_403": { "code": "FORBIDDEN", "message": "Only the original creator can edit this cost entry" },
        "response_409": { "code": "INVALID_TRANSITION", "message": "Cannot approve a REJECTED entry. Creator must re-submit first." },
        "side_effects_approve": [
