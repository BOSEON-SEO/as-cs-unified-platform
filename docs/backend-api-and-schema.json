  "section1_auto_assignment": {
    "title": "(1) Auto-Assignment Round-Robin",

    "db_schema": {
      "table_assignment_rules": {
        "name": "as_assignment_rules",
        "description": "Singleton config row (id=1). Stores auto-assignment global settings.",
        "ddl": [
          "CREATE TABLE as_assignment_rules (",
          "  id              TINYINT UNSIGNED NOT NULL DEFAULT 1 PRIMARY KEY,",
          "  enabled         BOOLEAN NOT NULL DEFAULT FALSE,",
          "  mode            ENUM('ROUND_ROBIN','LEAST_LOADED','CAPABILITY_MATCH') NOT NULL DEFAULT 'ROUND_ROBIN',",
          "  max_per_assignee INT UNSIGNED NOT NULL DEFAULT 20,",
          "  skip_sla_exceeded BOOLEAN NOT NULL DEFAULT TRUE,",
          "  prefer_same_customer BOOLEAN NOT NULL DEFAULT FALSE,",
          "  last_robin_user_id BIGINT UNSIGNED NULL COMMENT 'Last assigned user for round-robin rotation',",
          "  updated_at      DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,",
          "  updated_by      BIGINT UNSIGNED NULL,",
          "  CONSTRAINT chk_singleton CHECK (id = 1)",
          ") ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;"
        ]
      },
      "table_assignment_pool": {
        "name": "as_assignment_pool",
        "description": "Which users are in the auto-assignment pool and their ON/OFF status.",
        "ddl": [
          "CREATE TABLE as_assignment_pool (",
          "  pool_id         BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,",
          "  user_id         BIGINT UNSIGNED NOT NULL,",
          "  enabled         BOOLEAN NOT NULL DEFAULT TRUE,",
          "  created_at      DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,",
          "  updated_at      DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,",
          "  UNIQUE INDEX uq_pool_user (user_id),",
          "  CONSTRAINT fk_pool_user FOREIGN KEY (user_id) REFERENCES users(id)",
          ") ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;"
        ]
      }
    },

    "round_robin_algorithm": {
      "description": "Server-side algorithm executed on TICKET_CREATED when auto-assign is enabled",
      "pseudocode": [
        "function autoAssign(ticketId):",
        "  rules = SELECT * FROM as_assignment_rules WHERE id=1",
        "  if (!rules.enabled) return null",
        "",
        "  pool = SELECT ap.user_id, COUNT(t.ticket_id) AS current_count",
        "         FROM as_assignment_pool ap",
        "         LEFT JOIN as_tickets t ON t.assignee_id = ap.user_id",
        "              AND t.status NOT IN ('CLOSED','CANCELLED')",
        "         WHERE ap.enabled = TRUE",
        "         GROUP BY ap.user_id",
        "         ORDER BY ap.user_id",
        "",
        "  if (pool is empty) return null  -- no available crew",
        "",
        "  -- Apply filters",
        "  candidates = pool.filter(u => u.current_count < rules.max_per_assignee)",
        "",
        "  if (rules.skip_sla_exceeded):",
        "    slaExceeded = SELECT assignee_id, COUNT(*) AS cnt",
        "                  FROM as_tickets",
        "                  WHERE status NOT IN ('CLOSED','CANCELLED')",
        "                    AND sla_percent > 100",
        "                  GROUP BY assignee_id",
        "                  HAVING cnt >= 2",
        "    candidates = candidates.filter(u => u.user_id NOT IN slaExceeded)",
        "",
        "  if (rules.prefer_same_customer):",
        "    customer = ticket.customer_id",
        "    prevAssignee = SELECT assignee_id FROM as_tickets",
        "                   WHERE customer_id = customer AND ticket_id != ticketId",
        "                   ORDER BY created_at DESC LIMIT 1",
        "    if (prevAssignee IN candidates):",
        "      return assign(ticketId, prevAssignee, 'auto_same_customer')",
        "",
        "  if (candidates is empty) return null  -- all at capacity",
        "",
        "  -- Round-robin: pick next after last_robin_user_id",
        "  sortedIds = candidates.map(u => u.user_id).sort()",
        "  lastIdx = sortedIds.indexOf(rules.last_robin_user_id)",
        "  nextIdx = (lastIdx + 1) % sortedIds.length",
        "  selectedUserId = sortedIds[nextIdx]",
        "",
        "  -- Update rotation pointer",
        "  UPDATE as_assignment_rules SET last_robin_user_id = selectedUserId WHERE id=1",
        "",
        "  return assign(ticketId, selectedUserId, 'auto_round_robin')"
      ],
      "transactional": "Entire function runs in @Transactional with SERIALIZABLE isolation on as_assignment_rules row to prevent double-assign under concurrent ticket creation."
    },

    "api_endpoints": [
      {
